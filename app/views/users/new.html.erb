<% content_for :title, "Invite User" %>

<div class="container py-4" style="max-width: 480px;">
  <h1 class="mb-4">Invite User</h1>

  <%= form_with model: @user, url: users_path do |f| %>
    <% if @user.errors.any? %>
      <div class="alert alert-danger">
        <ul class="mb-0">
          <% @user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-3">
      <%= f.label :name, class: "form-label" %>
      <%= f.text_field :name, class: "form-control", autofocus: true %>
    </div>

    <div class="mb-3">
      <%= f.label :email, class: "form-label" %>
      <%= f.email_field :email, class: "form-control" %>
    </div>

    <div class="mb-4 form-check">
      <%= f.check_box :admin, class: "form-check-input" %>
      <%= f.label :admin, "Admin privileges", class: "form-check-label" %>
    </div>

    <div class="d-flex gap-2">
      <%= f.submit "Send Invite", class: "btn btn-primary" %>
      <%= link_to "Cancel", users_path, class: "btn btn-outline-secondary" %>
    </div>
  <% end %>
</div>
