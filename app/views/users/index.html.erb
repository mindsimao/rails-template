<% content_for :title, "Users" %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Users</h1>
    <%= link_to "Invite User", new_user_path, class: "btn btn-primary" %>
  </div>

  <table class="table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Admin</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td><%= user.name %></td>
          <td><%= user.email %></td>
          <td><%= user.admin? ? "Yes" : "No" %></td>
          <td class="text-end">
            <% unless user == current_user %>
              <%= button_to "Remove", user_path(user), method: :delete,
                    class: "btn btn-sm btn-outline-danger",
                    data: { turbo_confirm: "Remove #{user.name}?" } %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
